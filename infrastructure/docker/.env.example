# ============================================================
# SupportHub — Local Development Environment Variables
# Task: INFRA-001
#
# USAGE:
#   cp infrastructure/docker/.env.example infrastructure/docker/.env
#   # Edit .env with your local values (never commit .env)
#   docker compose --env-file infrastructure/docker/.env \
#     -f infrastructure/docker/docker-compose.yml up -d
#
# All values here are safe defaults for local development only.
# Never use these values in staging or production.
# ============================================================

# ============================================================
# PostgreSQL (Main Application DB)
# ============================================================
POSTGRES_DB=supporthub
POSTGRES_USER=supporthub
POSTGRES_PASSWORD=supporthub_dev_password
POSTGRES_PORT=5432

# JDBC URL for backend services (used in application.yml / env vars)
DB_URL=jdbc:postgresql://localhost:5432/supporthub
DB_TEST_URL=jdbc:postgresql://localhost:5432/supporthub_test

# ============================================================
# MongoDB
# ============================================================
MONGO_DB=supporthub
MONGO_USER=supporthub
MONGO_PASSWORD=supporthub_dev_password
MONGO_PORT=27017

MONGODB_URI=mongodb://supporthub:supporthub_dev_password@localhost:27017/supporthub?authSource=admin

# ============================================================
# Redis
# ============================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=supporthub_dev_password

# ============================================================
# Kafka / Zookeeper
# ============================================================
ZOOKEEPER_PORT=2181
KAFKA_PORT=9092
KAFKA_SERVERS=localhost:9092

# ============================================================
# Elasticsearch
# ============================================================
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_URI=http://localhost:9200

# ============================================================
# MinIO (S3-compatible object storage)
# ============================================================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# AWS SDK-compatible settings pointing at local MinIO
AWS_S3_ENDPOINT=http://localhost:9000
AWS_S3_BUCKET=supporthub-dev
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=ap-south-1

# ============================================================
# Strapi v5 CMS
# ============================================================
STRAPI_PORT=1337
STRAPI_POSTGRES_PORT=5433
STRAPI_DB_NAME=strapi
STRAPI_DB_USER=strapi
STRAPI_DB_PASSWORD=strapi_dev_password

# Strapi secrets — generate fresh values for staging/prod
# Use: openssl rand -base64 32
STRAPI_JWT_SECRET=a-very-long-secret-for-local-dev-only-change-in-prod
STRAPI_ADMIN_JWT_SECRET=another-very-long-secret-for-local-dev-only
STRAPI_APP_KEYS=key1,key2,key3,key4
STRAPI_API_TOKEN_SALT=a-salt-value-for-local-dev
STRAPI_TRANSFER_TOKEN_SALT=a-transfer-salt-value-for-local-dev

# ============================================================
# Backend Services — AI Service
# ============================================================
# NEVER commit real Anthropic keys. Add to AWS Secrets Manager in prod.
ANTHROPIC_API_KEY=sk-ant-REPLACE_WITH_REAL_KEY_DO_NOT_COMMIT
ANTHROPIC_SENTIMENT_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_RESOLUTION_MODEL=claude-sonnet-4-5

# Langfuse observability (optional in dev)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ============================================================
# Backend Services — Notification Service
# ============================================================
MSG91_API_KEY=REPLACE_WITH_REAL_KEY
MSG91_SENDER_ID=SUPHUB
SENDGRID_API_KEY=REPLACE_WITH_REAL_KEY
WHATSAPP_ACCESS_TOKEN=REPLACE_WITH_REAL_KEY

# ============================================================
# Backend Services — Auth / JWT
# ============================================================
# In production, keys are loaded from filesystem (PEM files).
# For local dev, Spring Boot auto-generates a keypair if not set.
JWT_PRIVATE_KEY_LOCATION=classpath:keys/private.pem
JWT_PUBLIC_KEY_LOCATION=classpath:keys/public.pem

# ============================================================
# General Spring Boot
# ============================================================
SPRING_PROFILES_ACTIVE=dev

# ============================================================
# Backend Services — PII Encryption (order-sync-service)
# Must be a Base64-encoded 32-byte (256-bit) AES key.
# Generate: openssl rand -base64 32
# The value below is a dev-only default (CHANGE IN PRODUCTION).
# ============================================================
ENCRYPTION_SECRET_KEY=55SrRelbg/GkQRz3sGIoGhc5q41G24EzV9949DW0Nro=
